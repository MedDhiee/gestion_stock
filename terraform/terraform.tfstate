    {
      "mode": "managed",
      "type": "kubernetes_config_map",
      "name": "prometheus_alert_rules",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "binary_data": null,
            "data": {
              "alert.rules.yml": "groups:\r\n  - name: AllInstances\r\n    rules:\r\n      - alert: InstanceDown\r\n        expr: up == 0\r\n        for: 1m\r\n        labels:\r\n          severity: \"critical\"\r\n        annotations:\r\n          summary: \"Instance {{ $labels.instance }} down\"\r\n          description: \"{{ $labels.instance }} of job {{ $labels.job }} has been down for more than 1 minute.\"\r\n\r\n  - name: HostStats\r\n    rules:\r\n      - alert: HostHighCpuLoad\r\n        expr: (100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)) \u003e 80\r\n        for: 5m\r\n        labels:\r\n          severity: \"warning\"\r\n        annotations:\r\n          summary: \"Host high CPU load (instance {{ $labels.instance }})\"\r\n          description: \"CPU load is \u003e 80%\\n  VALUE = {{ $value }}\\n  LABELS = {{ $labels }}\"\r\n\r\n      - alert: HostHighMemoryLoad\r\n        expr: (node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100 \u003e 80\r\n        for: 5m\r\n        labels:\r\n          severity: \"warning\"\r\n        annotations:\r\n          summary: \"Host high memory load (instance {{ $labels.instance }})\"\r\n          description: \"Memory usage is \u003e 80%\\n  VALUE = {{ $value }}\\n  LABELS = {{ $labels }}\"\r\n"
            },
            "id": "gestionstock/prometheus-alert-rules",
            "immutable": false,
            "metadata": [
              {
                "annotations": null,
                "generate_name": "",
                "generation": 0,
                "labels": null,
                "name": "prometheus-alert-rules",
                "namespace": "gestionstock",
                "resource_version": "53502",
                "uid": "19af676c-dcf7-4f15-929b-60e2739ee223"
              }
            ]
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA==",
          "dependencies": [
            "kubernetes_namespace.app_namespace"
          ]
        }
      ]
