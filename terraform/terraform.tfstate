            "data": {
              "config.yml": "global:\r\n  resolve_timeout: 5m\r\n\r\nroute:\r\n  group_by: [\"alertname\", \"cluster\", \"service\"]\r\n  group_wait: 30s\r\n  group_interval: 5m\r\n  repeat_interval: 4h\r\n  receiver: \"slack-notifications\"\r\n\r\nreceivers:\r\n  - name: \"slack-notifications\"\r\n    slack_configs:\r\n      - api_url: \"https://hooks.slack.com/services/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\"\r\n        channel: \"#alerts\"\r\n        send_resolved: true\r\n"
            },
            "id": "gestionstock/alertmanager-config",
            "immutable": false,
            "metadata": [
              {
                "annotations": null,
