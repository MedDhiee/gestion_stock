              "prometheus.yml": "global:\r\n  scrape_interval: 15s\r\n\r\nrule_files:\r\n  - /etc/prometheus/alert.rules.yml\r\n\r\nalerting:\r\n  alertmanagers:\r\n  - static_configs:\r\n    - targets:\r\n      - 'alertmanager:9093'\r\n\r\nscrape_configs:\r\n  - job_name: 'gestiondestock-api'\r\n    metrics_path: '/actuator/prometheus'\r\n    static_configs:\r\n      - targets: ['gestiondestock-api:8081']\r\n"
            },
